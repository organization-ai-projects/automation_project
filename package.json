{
  "name": "automation_project",
  "version": "1.0.0",
  "private": true,
  "description": "Markdown linting configuration for automation_project",
  "scripts": {
    "lint-md": "markdownlint-cli2 \"**/*.md\" \"#target\" \"#node_modules\"",
    "lint-md-fix": "markdownlint-cli2 --fix \"**/*.md\" \"#target\" \"#node_modules\"",
    "lint-md-files": "sh -c 'markdownlint-cli2 \"#target\" \"#node_modules\" \"$@\"' --",
    "lint-md-fix-files": "sh -c 'markdownlint-cli2 --fix \"#target\" \"#node_modules\" \"$@\"' --",
    "enforcer:watch": "pnpm --dir tools/vscode/repo-contract-enforcer-extension run dev",
    "vsix": "pnpm --dir tools/vscode/repo-contract-enforcer-extension run vsix",
    "vsix:pack": "pnpm --dir tools/vscode/repo-contract-enforcer-extension run vsix:pack",
    "vsix:install": "pnpm --dir tools/vscode/repo-contract-enforcer-extension run vsix:install",
    "vsix:reinstall": "pnpm --dir tools/vscode/repo-contract-enforcer-extension run vsix:reinstall",
    "vsix:watch": "pnpm --dir tools/vscode/repo-contract-enforcer-extension run vsix:watch"
  },
  "devDependencies": {
    "markdownlint-cli2": "^0.21.0"
  }
}

#!/usr/bin/env bash
# Git hook: pre-push
# Runs scope-aware formatting, linting, and tests before push
# Bypass: SKIP_PRE_PUSH=1 git push ...
set -euo pipefail

if [[ "${SKIP_PRE_PUSH:-}" == "1" ]]; then
	echo "⚠️  Pre-push checks skipped (SKIP_PRE_PUSH=1)"
	exit 0
fi

echo "🔍 Running pre-push checks..."
echo ""

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT" || exit 1
HOOKS_DIR="$REPO_ROOT/scripts/automation/git_hooks"
# shellcheck source=scripts/automation/git_hooks/lib/push_policy.sh
source "$HOOKS_DIR/lib/push_policy.sh"
# shellcheck source=scripts/common_lib/automation/rust_checks.sh
source "$REPO_ROOT/scripts/common_lib/automation/rust_checks.sh"

UPSTREAM_BRANCH="$(push_policy_resolve_upstream_branch)"
commits="$(push_policy_collect_push_commits "$UPSTREAM_BRANCH")"

if ! push_policy_validate_no_root_parent_issue_refs "$commits"; then
	exit 1
fi

if ! push_policy_validate_part_of_only_push "$commits"; then
	exit 1
fi

changed_files="$(push_policy_compute_changed_files "$UPSTREAM_BRANCH")"
markdown_files="$(push_policy_collect_markdown_files "$changed_files")"

if is_docs_or_scripts_only_change "$changed_files"; then
	echo "📄 Docs/scripts-only changes detected."
	echo "🧪 Skipping Rust fmt/clippy/tests for this push."
	if [[ -n "$markdown_files" ]]; then
		echo "📝 Running markdownlint on changed markdown files..."
		if ! push_policy_run_markdownlint_checks "$markdown_files"; then
			echo ""
			echo "❌ Markdown lint failed."
			exit 1
		fi
		echo "✅ Markdown lint OK"
	else
		echo "📝 Skipping markdownlint (no markdown files changed)."
	fi
	echo "🔎 Running lightweight shell syntax checks..."
	push_policy_run_shell_syntax_checks "$changed_files"
	echo ""
	echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
	echo "✅ Pre-push checks PASSED (docs/scripts-only mode)"
	echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
	echo ""
	exit 0
fi

set +e
AFFECTED="$(push_policy_detect_crates_from_scopes "$commits")"
SCOPE_VALID=$?
set -e

LOCKED_ARGS=()
if rust_checks_has_lockfile; then
	LOCKED_ARGS=(--locked)
fi

if [[ $SCOPE_VALID -ne 0 ]] || [[ -z "$AFFECTED" ]]; then
	AFFECTED="$(collect_crates_from_files "$changed_files")"
	if [[ -n "$AFFECTED" ]]; then
		echo "⚠️  Missing/invalid commit scopes - using changed files to infer crates."
		if [[ "${SCOPES_HAD_INVALID:-0}" -eq 1 ]]; then
			echo "   Tip: use scopes like 'refactor(projects/libraries/layers/domain/security):' or 'fix(projects/products/stable/accounts/backend):'"
		fi
		echo "🎯 Crates inferred from changed files:"
		echo "$AFFECTED" | sed 's/^/   - /'
		echo ""
		CLIPPY_ARGS=("${LOCKED_ARGS[@]}" --all-targets --all-features)
		TEST_ARGS=("${LOCKED_ARGS[@]}" --all-targets --all-features)
		while IFS= read -r crate; do
			[[ -z "$crate" ]] && continue
			CLIPPY_ARGS+=(-p "$crate")
			TEST_ARGS+=(-p "$crate")
		done <<<"$AFFECTED"
	else
		echo "⚠️  Could not infer affected crates - testing full workspace."
		echo "   (Use scopes like 'refactor(projects/libraries/layers/domain/security):' or 'fix(projects/products/stable/accounts/backend):')"
		echo ""
		CLIPPY_ARGS=("${LOCKED_ARGS[@]}" --workspace --all-targets --all-features)
		TEST_ARGS=("${LOCKED_ARGS[@]}" --workspace --all-targets --all-features)
	fi
else
	echo "🎯 Crates from commit scopes:"
	echo "$AFFECTED" | sed 's/^/   - /'
	echo ""
	CLIPPY_ARGS=("${LOCKED_ARGS[@]}" --all-targets --all-features)
	TEST_ARGS=("${LOCKED_ARGS[@]}" --all-targets --all-features)
	while IFS= read -r crate; do
		[[ -z "$crate" ]] && continue
		CLIPPY_ARGS+=(-p "$crate")
		TEST_ARGS+=(-p "$crate")
	done <<<"$AFFECTED"
fi

FAILED=0

if [[ -n "$markdown_files" ]]; then
	echo "📝 Running markdownlint on changed markdown files..."
	if ! push_policy_run_markdownlint_checks "$markdown_files"; then
		echo ""
		echo "❌ Markdown lint failed."
		echo "   Run: pnpm run lint-md-files -- <changed .md files>"
		echo ""
		FAILED=1
	else
		echo "✅ Markdown lint OK"
		echo ""
	fi
fi

echo "📝 Checking code formatting..."
if ! rust_checks_run_fmt_check; then
	echo ""
	echo "❌ Code formatting check failed!"
	echo "   Run: cargo fmt --all"
	echo ""
	FAILED=1
else
	echo "✅ Formatting OK"
	echo ""
fi

echo "🔎 Running clippy..."
if ! rust_checks_run_clippy "${CLIPPY_ARGS[@]}"; then
	echo ""
	echo "❌ Clippy found issues!"
	echo "   Run: cargo clippy ${CLIPPY_ARGS[*]} -- -D warnings"
	echo ""
	FAILED=1
else
	echo "✅ Clippy OK"
	echo ""
fi

echo "🧪 Running tests..."
if ! rust_checks_run_tests "${TEST_ARGS[@]}"; then
	echo ""
	echo "❌ Tests failed!"
	echo "   Run: cargo test ${TEST_ARGS[*]}"
	echo ""
	FAILED=1
else
	echo "✅ Tests OK"
	echo ""
fi

if [[ $FAILED -eq 1 ]]; then
	echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
	echo "❌ Pre-push checks FAILED"
	echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
	echo ""
	echo "Please fix the issues before pushing."
	echo "Bypass (emergency only): SKIP_PRE_PUSH=1 git push"
	echo ""
	exit 1
fi

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "✅ All pre-push checks PASSED"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

exit 0

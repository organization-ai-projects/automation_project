{
  "name": "repo-contract-enforcer-diagnostics",
  "displayName": "Repo Contract Enforcer Diagnostics",
  "description": "Inline diagnostics from repo_contract_enforcer rules (team patterns).",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "scripts": {
    "vsix": "npm run vsix:pack",
    "vsix:pack": "rm -f repo-contract-enforcer-diagnostics-*.vsix && vsce package --allow-missing-repository --no-dependencies",
    "vsix:install": "bash ./scripts/reinstall-local.sh",
    "vsix:reinstall": "bash ./scripts/repack-reinstall.sh",
    "vsix:watch": "bash ./scripts/watch-reinstall.sh"
  },
  "files": [
    "extension.js",
    "package.json",
    "README.md"
  ],
  "categories": [
    "Linters"
  ],
  "activationEvents": [
    "workspaceContains:Cargo.toml",
    "onLanguage:rust"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "repoContractEnforcer.runCheck",
        "title": "Repo Contract Enforcer: Run Check"
      },
      {
        "command": "repoContractEnforcer.showOutput",
        "title": "Repo Contract Enforcer: Show Output"
      }
    ],
    "configuration": {
      "title": "Repo Contract Enforcer",
      "properties": {
        "repoContractEnforcer.mode": {
          "type": "string",
          "enum": [
            "auto",
            "strict",
            "relaxed"
          ],
          "default": "auto",
          "description": "Mode passed to repo_contract_enforcer_ui"
        },
        "repoContractEnforcer.runOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run checks automatically when Rust/TOML files are saved"
        },
        "repoContractEnforcer.runOnChange": {
          "type": "boolean",
          "default": true,
          "description": "Run checks while editing Rust/TOML files (debounced)"
        },
        "repoContractEnforcer.runOnFileEvents": {
          "type": "boolean",
          "default": true,
          "description": "Run checks on Rust/TOML file create/change/delete/rename events"
        },
        "repoContractEnforcer.debounceMs": {
          "type": "number",
          "default": 300,
          "minimum": 50,
          "maximum": 5000,
          "description": "Debounce delay in milliseconds for edit/file-event triggered checks"
        },
        "repoContractEnforcer.runTimeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 1000,
          "maximum": 120000,
          "description": "Maximum runtime for one check process before forced interruption"
        },
        "repoContractEnforcer.command": {
          "type": "string",
          "default": "cargo",
          "description": "Command used to invoke cargo (or an equivalent build tool) for the backend check process"
        },
        "repoContractEnforcer.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "run",
            "-q",
            "-p",
            "repo_contract_enforcer_backend",
            "--",
            "serve"
          ],
          "description": "Arguments passed to repoContractEnforcer.command when launching the backend check process"
        },
        "repoContractEnforcer.outputChannelEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose stdout/stderr logging in the extension output channel"
        }
      }
    }
  }
}
